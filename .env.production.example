# Safarim.uz — PRODUCTION env.
# Nusxa oling:  cp .env.production.example .env.production  va qiymatlarni to'ldiring.
# Bu fayl ham compose interpolyatsiyasi (${...}), ham konteyner env'i uchun ishlatiladi.

# ── App ──
APP_NAME=Safarim.uz
APP_VERSION=1.0.0
DEBUG=false
# Kuchli kalitlar:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=__TODO_kuchli_kalit__
JWT_SECRET_KEY=__TODO_kuchli_kalit__
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS (aniq domen, "*" bloklanadi) ──
CORS_ORIGINS=https://safarim.uz,https://www.safarim.uz

# ── Database (compose ichida db hostiga ulanadi) ──
POSTGRES_DB=safarim
POSTGRES_USER=safarim
POSTGRES_PASSWORD=__TODO_kuchli_parol__

# ── OTP + Rate limiting ──
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RATELIMIT_PHONE_PER_HOUR=5
OTP_RATELIMIT_IP_PER_HOUR=15
LOGIN_RATELIMIT_PER_15MIN=10
# Pilot rejim: SMS'siz sinov uchun OTP javobda qaytadi (testerlar ekranda ko'radi).
# ⚠️ Faqat yopiq pilot uchun! Haqiqiy ishga tushirishda false qiling.
PILOT_MODE=true

# ── MinIO ──
MINIO_ACCESS_KEY=__TODO__
MINIO_SECRET_KEY=__TODO_kuchli_parol__
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_PHOTOS=photos
MINIO_SECURE=false
# Brauzer ko'radigan public MinIO manzili (rasm/avatar). Pilot: SERVER_IP:9000
# Domen + HTTPS bo'lsa: cdn.safarim.uz va MINIO_PUBLIC_SECURE=true
MINIO_PUBLIC_ENDPOINT=__TODO_SERVER_IP__:9000
MINIO_PUBLIC_SECURE=false

# ── SMS - Eskiz.uz ──
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_BASE_URL=https://notify.eskiz.uz/api

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── To'lov ──
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_ID=
PAYME_KEY=

# ── Komissiya / reyting ──
COMMISSION_LOW_RATE=0.02
COMMISSION_HIGH_RATE=0.05
COMMISSION_THRESHOLD=200000
RATING_WARNING_THRESHOLD=4.0
RATING_BLOCK_THRESHOLD=3.5
REVIEW_DEADLINE_HOURS=72

# ── Monitoring (Sentry) ──
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Backup ──
BACKUP_RETENTION_DAYS=14

# ── Gunicorn ──
WEB_CONCURRENCY=3
