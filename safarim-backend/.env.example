# App
APP_NAME=Safarim.uz
APP_VERSION=1.0.0
# DEBUG=false bo'lganda xavfsiz bo'lmagan default qiymatlar bilan ishga tushmaydi
DEBUG=true
# Kuchli kalit hosil qilish: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production

# CORS — prod'da aniq domenlar (vergul bilan). "*" prod'da bloklanadi.
CORS_ORIGINS=http://localhost:3000

# Database
POSTGRES_DB=safarim
POSTGRES_USER=safarim
POSTGRES_PASSWORD=safarim123
DATABASE_URL=postgresql+asyncpg://safarim:safarim123@localhost:5432/safarim

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3

# Rate limiting (Redis orqali)
OTP_RATELIMIT_PHONE_PER_HOUR=5
OTP_RATELIMIT_IP_PER_HOUR=15
LOGIN_RATELIMIT_PER_15MIN=10

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_PHOTOS=photos
MINIO_SECURE=false

# SMS - Eskiz.uz
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_BASE_URL=https://notify.eskiz.uz/api

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Click To'lov
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret-key

# Payme To'lov
PAYME_ID=your-payme-id
PAYME_KEY=your-payme-key

# Komissiya
COMMISSION_LOW_RATE=0.02
COMMISSION_HIGH_RATE=0.05
COMMISSION_THRESHOLD=200000

# Reyting chegaralari
RATING_WARNING_THRESHOLD=4.0
RATING_BLOCK_THRESHOLD=3.5

# Baho muddati (soat)
REVIEW_DEADLINE_HOURS=72
